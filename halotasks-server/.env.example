PORT=5000
MONGO_URI=
MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1
JWT_SECRET=
CLIENT_ORIGIN=http://localhost:5173
APP_BASE_URL=http://localhost:5173

# Email Transport (SMTP takes priority if all vars present)
# Primary: SMTP (optional - if all SMTP_* vars set, will be used first)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Secondary: Resend (fallback if SMTP unavailable)
RESEND_API_KEY=
EMAIL_FROM=HaloTaskPro <no-reply@yourdomain.com>

# Password Reset
RESET_TOKEN_TTL_MINUTES=20
